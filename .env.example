# Copy to .env and fill in. NEVER commit .env.

# --- Backend ---
PORT=4000
# Simulated office clock: how many sim-seconds pass per real second.
# 60 = one real minute is one office hour (great for demos). Set 1 for real time.
SIM_TIME_SCALE=60
# Where the simulated office day starts when the backend boots (HH:MM, 24h).
# Kept at exactly 09:00 (office-hours open) so a fresh start never shows an
# "early arrival" device as a false after-hours alert in the first ~30s.
SIM_START_TIME=09:00

# --- Discord bot ---
DISCORD_BOT_TOKEN=
# Channel ID the bot posts proactive alerts into (right-click channel -> Copy Channel ID)
DISCORD_ALERT_CHANNEL_ID=
# Backend the bot reads from
BACKEND_URL=http://localhost:4000

# --- LLM humanization (optional — bot falls back to friendly templates without it) ---
# Get a key at console.groq.com (note: Groq, the inference platform — not
# xAI's Grok model; easy to mix up). Bot phrasing only, never a source of numbers.
GROQ_API_KEY=
# Defaults to llama-3.3-70b-versatile if left blank.
GROQ_MODEL=
