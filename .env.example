# Copy to .env and fill in. NEVER commit .env.

# --- Backend ---
PORT=4000
# Simulated office clock: how many sim-seconds pass per real second.
# 60 = one real minute is one office hour (great for demos). Set 1 for real time.
SIM_TIME_SCALE=60
# Where the simulated office day starts when the backend boots (HH:MM, 24h)
SIM_START_TIME=08:30

# --- Discord bot ---
DISCORD_BOT_TOKEN=
# Channel ID the bot posts proactive alerts into (right-click channel -> Copy Channel ID)
DISCORD_ALERT_CHANNEL_ID=
# Backend the bot reads from
BACKEND_URL=http://localhost:4000

# --- LLM humanization (optional — bot falls back to templates without it) ---
ANTHROPIC_API_KEY=
